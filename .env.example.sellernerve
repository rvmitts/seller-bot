# SellerNerve env example — names only, no real secrets

# --- API / DB ---
DATABASE_URL=postgresql://sellernerve:sellernerve@localhost:5432/sellernerve
NODE_ENV=development
LOG_LEVEL=info
PORT=3000
# Set to "false" to skip automatic migrations on server startup.
AUTO_MIGRATE=true

# --- Telegram (Pass 2) ---
# Bot token issued by @BotFather. NEVER commit a real value.
TELEGRAM_BOT_TOKEN=replace_me
# Public bot @handle (e.g. SellerNerveBot — no leading @). Used only in docs and error messages.
TELEGRAM_BOT_ADDRESS=replace_me
# Shared secret echoed by Telegram in the X-Telegram-Bot-Api-Secret-Token header.
# Generate with: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=replace_me
# Public HTTPS base URL for the running API (ngrok / cloudflared / localtunnel).
# Example: https://example.trycloudflare.com
APP_BASE_URL=https://example.trycloudflare.com
# OPTIONAL override. Pass 2 captures chat_id from /start automatically; only set this if you want
# to force a specific chat instead of using the most-recently-captured one.
# TELEGRAM_TEST_CHAT_ID=

# --- WB (Pass 3) ---
# Production Wildberries API token. Loaded from environment only. NEVER commit.
# Read-only, GET-only validation only — Pass 3 never mutates WB data.
WB_API_TOKEN=replace_me
# Optional host override. Defaults to https://common-api.wildberries.ru.
# Override to a *-sandbox.wildberries.ru host to validate a Test scope token.
# WB_API_HOST=https://common-api.wildberries.ru
# Optional path overrides; defaults shown.
# WB_PING_PATH=/ping
# WB_SELLER_INFO_PATH=/api/v1/seller-info
# Per-request timeout (ms). Default 10000.
# WB_TIMEOUT_MS=10000
# Number of trailing characters retained when masking the token in reports.
# WB_TOKEN_MASK_TAIL=4
